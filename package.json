{
	"type": "module",
	"name": "@sinamtz/pi-mempalace",
	"version": "0.1.4",
	"description": "hasslefree and self-contained mempalace port for pi-coding-agent with SurrealDB-backed vector search, layered retrieval, and multi-process auto-server runtime",
	"homepage": "https://github.com/sinamtz/pi-mempalace#readme",
	"author": {
		"name": "Sina Montazeri"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sinamtz/pi-mempalace.git"
	},
	"bugs": {
		"url": "https://github.com/sinamtz/pi-mempalace/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"mempalace",
		"pi-mempalace",
		"memory",
		"vector-search",
		"knowledge-graph",
		"surrealdb",
		"embedding"
	],
	"pi": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"fmt": "biome format --write .",
	"test": "vitest run",
		"test:unit": "vitest run test/fs-error.test.ts test/logger.test.ts test/surreal-binary.test.ts test/extension.test.ts test/singleton.test.ts",
		"test:crossprocess": "node test/singleton-crossprocess.ts",
		"test:integration": "vitest run test/memory.test.ts test/miner.test.ts test/kg/kg.test.ts test/phase5.test.ts",
		"test:all": "vitest run && node test/singleton-crossprocess.ts"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.0.1",
		"@sinclair/typebox": "^0.34.49",
		"ignore": "^7.0.5",
		"surrealdb": "^2.0.3",
		"ws": "^8.18.1"
	},
	"devDependencies": {
		"@mariozechner/pi-coding-agent": "^0.66.1",
		"@mariozechner/pi-tui": "^0.66.1",
		"@types/bun": "^1.3.11",
		"@types/ws": "^8.18.1",
		"vitest": "^4.1.4"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"engines": {
		"node": ">=20.6.0",
		"bun": ">=1.3.7"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	]
}
